# Supabase Configuration (Wajib)
# Ambil dari: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# RevenueCat Configuration (Wajib untuk iOS)
# Ambil dari: RevenueCat Dashboard -> Project Settings -> API Keys -> App Store (iOS)
NEXT_PUBLIC_REVENUECAT_IOS_KEY=your-revenuecat-ios-key

# Google Auth Configuration (Wajib untuk Login)
# Gunakan iOS Client ID dari Google Cloud Console
NEXT_PUBLIC_GOOGLE_CLIENT_ID=1031627117513-v2uh5j60iodalgou66ighsc9ohivc7a8.apps.googleusercontent.com
